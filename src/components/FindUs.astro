---
---
<section class="py-28 px-6 bg-plaster" id="trouver">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">

      <!-- Address block -->
      <div class="reveal">
        <h2 class="font-display text-4xl font-bold text-charcoal mb-2">Nous Trouver</h2>
        <div class="w-12 h-px bg-terracotta mb-8"></div>

        <!-- Large typographic address -->
        <div class="mb-8">
          <p class="font-display text-3xl font-bold text-charcoal leading-tight">Le Panier,</p>
          <p class="font-display text-3xl font-bold text-charcoal leading-tight mb-4">Marseille</p>
          <p class="font-body text-base text-warm-gray">14 Rue de la Loge</p>
          <p class="font-body text-base text-warm-gray">13002 Marseille, France</p>
        </div>

        <!-- Walking note -->
        <p class="font-accent text-lg text-terracotta -rotate-1 inline-block mb-10">
          À 5 minutes du Vieux-Port, cherchez la porte terracotta.
        </p>

        <!-- Hours -->
        <div>
          <p class="font-body text-xs text-warm-gray uppercase tracking-widest mb-3">Horaires</p>
          <p class="font-display text-xl font-bold text-charcoal">Mardi – Samedi</p>
          <p class="font-body text-base text-charcoal">18h – 00h</p>
          <p class="font-body text-sm text-warm-gray mt-1">Fermé dimanche et lundi</p>
        </div>
      </div>

      <!-- Contact block -->
      <div class="reveal">
        <p class="font-body text-xs text-warm-gray uppercase tracking-widest mb-8">Contact</p>

        <div class="flex flex-col gap-6">
          <div>
            <p class="font-body text-xs text-warm-gray mb-1">Email</p>
            <a href="mailto:bonjour@trouvaille-marseille.fr" class="font-body text-base text-charcoal hover:text-terracotta transition-colors duration-200 border-b border-warm-gray/30 hover:border-terracotta pb-0.5">
              bonjour@trouvaille-marseille.fr
            </a>
          </div>

          <div>
            <p class="font-body text-xs text-warm-gray mb-1">Instagram</p>
            <a href="#" class="font-body text-base text-charcoal hover:text-terracotta transition-colors duration-200 border-b border-warm-gray/30 hover:border-terracotta pb-0.5">
              @trouvaille.marseille
            </a>
          </div>
        </div>

        <!-- Decorative dots -->
        <div class="flex gap-2 mt-16" aria-hidden="true">
          <span class="w-2 h-2 rounded-full bg-terracotta opacity-50"></span>
          <span class="w-2 h-2 rounded-full bg-terracotta opacity-30"></span>
          <span class="w-2 h-2 rounded-full bg-terracotta opacity-15"></span>
        </div>
      </div>

    </div>
  </div>
</section>
