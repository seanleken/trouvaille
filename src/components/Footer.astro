<footer class="py-16 px-6 bg-cream border-t border-warm-gray/20">
  <div class="max-w-6xl mx-auto text-center">
    <!-- Terracotta rule -->
    <div class="flex items-center justify-center gap-4 mb-10" aria-hidden="true">
      <span class="w-8 h-px bg-terracotta opacity-40"></span>
      <span class="w-1.5 h-1.5 rounded-full bg-terracotta opacity-50"></span>
      <span class="w-1.5 h-1.5 rounded-full bg-terracotta opacity-30"></span>
      <span class="w-1.5 h-1.5 rounded-full bg-terracotta opacity-50"></span>
      <span class="w-8 h-px bg-terracotta opacity-40"></span>
    </div>

    <!-- Logo wordmark -->
    <p class="font-display text-2xl font-bold text-charcoal mb-3">Trouvaille</p>

    <!-- Address -->
    <p class="font-body text-sm text-warm-gray mb-8">
      14 Rue de la Loge · Le Panier · 13002 Marseille
    </p>

    <!-- Sign-off -->
    <p class="font-accent text-2xl text-terracotta -rotate-1 inline-block">
      Buvez ce que vous aimez.
    </p>

    <p class="font-body text-xs text-warm-gray/50 mt-10">
      © 2024 Trouvaille · Bar à Vins Naturels
    </p>
  </div>
</footer>
